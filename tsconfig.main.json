  "compilerOptions": {
    "outDir": "dist/main",
    "rootDir": "src/main",
    "module": "commonjs",
    "target": "ES2020",
    "sourceMap": true,
    "declaration": false
  },
  "include": [
    "src/main/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
} 